        private void tcFormulas_SelectedIndexChanged(object sender, EventArgs e)
        {
            var selected = (clsFormulas.enFormulaType)tcFormulas.SelectedIndex;

            switch (selected)
            {
                case clsFormulas.enFormulaType.enWeightedFormula:
                    lblRunningTime.Visible = true;
                    lblRunningTimeFormula2.Visible = false;

                    cbChooseFormula.Visible = false;
                    lblSchedluingFormula.Visible = false;

                    break;

                case clsFormulas.enFormulaType.enPenaltyFormula:
                    lblRunningTime.Visible = false;
                    lblRunningTimeFormula2.Visible = true;

                    cbChooseFormula.Visible = false;
                    lblSchedluingFormula.Visible = false ;


                    break;

                case clsFormulas.enFormulaType.both:
                    lblRunningTime.Visible = true;
                    lblRunningTimeFormula2.Visible = true;

                    cbChooseFormula.Visible = true;
                    lblSchedluingFormula.Visible = true;
                    cbChooseFormula.SelectedIndex = -1;
                    break;
            }
        }

