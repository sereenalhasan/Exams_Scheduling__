        private bool SaveScheduleByFormula(
       (Chromosome bestChromosome, List<GenerationStats> stats) Results)
        {
            List<SaveFormGene> convertedGenes =
                Results.bestChromosome.Genes
                .SelectMany(g => g.RoomIDs.Select(roomId => new SaveFormGene
                {
                    ExamID = g.ExamID,
                    RoomID = roomId,
                    SupervisorID = g.SupervisorID,
                    ExamDateID = g.ExamDateID,
                    TimeSlotID = g.TimeSlotID
                }))
                .ToList();

            return SaveFinalSchedule.SaveSchedule(convertedGenes);
        }

        private void ShowSaveResult(bool result, string formulaName)
        {
            if (result)
            {
                MessageBox.Show(
                    $"Schedule saved successfully [{formulaName}]",
                    "Save",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Information);
            }
            else
            {
                MessageBox.Show(
                    $"Schedule can't be saved [{formulaName}]",
                    "Error",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Error);
            }
        }
        private bool CheckScheduleGenerated(
        (Chromosome bestChromosome, List<GenerationStats> stats) results)
        {
            if (results.bestChromosome == null)
            {
                errorProvider_Schedule.SetError(
                    button1,
                    "Please generate schedule first.");

                MessageBox.Show(
                    "Please click Scheduling button first.",
                    "No Schedule Found",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Warning);

                return false;
            }

            errorProvider_Schedule.SetError(button1, "");
            return true;
        }

        private void button1_Click(object sender, EventArgs e)
        {
            switch ((clsFormulas.enFormulaType)tcFormulas.SelectedIndex)
            {
                case clsFormulas.enFormulaType.enWeightedFormula:
                    {
                        if (!CheckScheduleGenerated(Results_WeightedFormula))
                            return;

                        if (MessageBox.Show(
                            "Are you sure you want to save using Weighted Formula?",
                            "Confirm Save",
                            MessageBoxButtons.YesNo,
                            MessageBoxIcon.Question)
                            != DialogResult.Yes)
                            return;

                        bool result = SaveScheduleByFormula(Results_WeightedFormula);
                        ShowSaveResult(result, "Weighted Formula");
                    }
                    break;

                case clsFormulas.enFormulaType.enPenaltyFormula:
                    {
                        if (!CheckScheduleGenerated(Results_Hard_SoftConstraintsFormula))
                            return;

                        if (MessageBox.Show(
                            "Are you sure you want to save using Hard/Soft Constraint Formula?",
                            "Confirm Save",
                            MessageBoxButtons.YesNo,
                            MessageBoxIcon.Question)
                            != DialogResult.Yes)
                            return;

                        bool result = SaveScheduleByFormula(
                            Results_Hard_SoftConstraintsFormula);

                        ShowSaveResult(result, "Hard/Soft Constraint Formula");
                    }
                    break;

                case clsFormulas.enFormulaType.both:
                    {
                        errorProvider_Save.SetError(cbChooseFormula, "");

                        // must choose formula
                        if (cbChooseFormula.SelectedIndex == -1)
                        {
                            errorProvider_Save.SetError(
                                cbChooseFormula,
                                "Please choose a formula first.");

                            cbChooseFormula.Focus();
                            return;
                        }

                        bool isWeighted = cbChooseFormula.SelectedIndex == 0;

                        // check correct schedule exists
                        if (isWeighted)
                        {
                            if (!CheckScheduleGenerated(Results_WeightedFormula))
                                return;
                        }
                        else
                        {
                            if (!CheckScheduleGenerated(Results_Hard_SoftConstraintsFormula))
                                return;
                        }

                        string formulaName = isWeighted
                            ? "Weighted Formula"
                            : "Hard/Soft Constraint Formula";

                        if (MessageBox.Show(
                            $"Are you sure you want to save using:\n{formulaName} ?",
                            "Confirm Save",
                            MessageBoxButtons.YesNo,
                            MessageBoxIcon.Question)
                            != DialogResult.Yes)
                            return;

                        bool result = isWeighted
                            ? SaveScheduleByFormula(Results_WeightedFormula)
                            : SaveScheduleByFormula(Results_Hard_SoftConstraintsFormula);

                        ShowSaveResult(result, formulaName);
                    }
                    break;
            }
        }
