        private bool HasValidResults((Chromosome bestChromosome, List<GenerationStats> stats) Results)
        {
            return Results.bestChromosome != null
                && Results.stats != null
                && Results.stats.Count != 0;
        }
        private void CheckMissingExams((Chromosome bestChromosome, List<GenerationStats> stats) Results )
        {
            var scheduledIDs = new HashSet<int>(
                Results.bestChromosome.Genes.Select(g => g.ExamID));

            var missingExams = _loader.ExamsIDs
                .Where(id => !scheduledIDs.Contains(id))
                .ToList();

            if (missingExams.Count > 0)
            {
                StringBuilder sb = new StringBuilder();

                sb.AppendLine($"{missingExams.Count} exam(s) not scheduled: \n");

                foreach (int examID in missingExams)
                {
                    int courseID = _loader.Exams[examID].CourseID;
                    int requiredCapacity = _loader.Exams[examID].RequiredCapacity;

                    bool hasSupervisors =
                        _loader.CourseDoctorMap.TryGetValue(courseID, out List<int> supervisors);

                    sb.AppendLine($"Exam {examID}:");
                    sb.AppendLine($"  CourseID         : {courseID}");
                    sb.AppendLine($"  RequiredCapacity : {requiredCapacity}");
                    sb.AppendLine($"  HasSupervisors   : {hasSupervisors && supervisors?.Count > 0}");
                    sb.AppendLine("---");
                }

                MessageBox.Show(
                    sb.ToString(),
                    "Missing Exams",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Warning);
            }
            else
            {
                MessageBox.Show(
                    $"All {_loader.ExamsIDs.Count} exams scheduled successfully!\n" +
                    $"Fitness Score : {Results.bestChromosome.Fitness_Score:F4}",
                    "Success",
                    MessageBoxButtons.OK,
                    MessageBoxIcon.Information);
            }
        }
        private List<GeneDisplayRow> LoadGenesToGrid((Chromosome bestChromosome, List<GenerationStats> stats)  Results)
        {
            List<GeneDisplayRow> geneList = new List<GeneDisplayRow>()  ;

            if (Results.bestChromosome == null)
                return null;

            foreach (Gene gene in Results.bestChromosome.Genes)
            {
                GeneDisplayRow g = new GeneDisplayRow();

                // Course Name
                g.CourseName =
                    _loader.GetCourseName(
                        _loader.Exams[gene.ExamID].CourseID
                    ).CourseName;

                // Room Names
                g.RoomName = string.Join(", ",
                    gene.RoomIDs
                        .Where(roomID => _loader.Rooms.ContainsKey(roomID))
                        .Select(roomID => _loader.Rooms[roomID].RoomNo)
                );

                // Supervisor
                g.SupervisorID = gene.SupervisorID;

                // Date
                g.Date =
                    _loader.Dates[gene.ExamDateID]
                    .ExamDate
                    .ToShortDateString();

                // Time Slot
                var timeSlot = _loader.GetTimeSlotInfo(gene.TimeSlotID);

                g.TimeSlot =
                    timeSlot.StartTimeSlot +
                    " - " +
                    timeSlot.EndTimeSlot;

                // Fitness Score
                g.FitnessScore =
                    Results.bestChromosome.Fitness_Score;

                geneList.Add(g);
            }

            return geneList;
        }
